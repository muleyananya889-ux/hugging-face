{
  "version": 2,
  "buildCommand": "pip install requests",
  "outputDirectory": ".",
  "installCommand": "pip install requests",
  "framework": null,
  "functions": {
    "index.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.py"
    }
  ]
}